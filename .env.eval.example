# Copy to .env.eval and fill in paths. Never commit .env.eval.

# ── Inference ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:26b
OLLAMA_HOST=http://localhost:11434

# ── Judge ─────────────────────────────────────────────────────────────────────
JUDGE_MODEL=qwen2.5:14b
LITELLM_PORT=4000

# ── MLflow (optional — defaults to local mlruns/) ─────────────────────────────
# MLFLOW_TRACKING_URI=http://localhost:5000

# ── LongMemEval scorer scripts (absolute paths on your pod) ──────────────────
EVALUATE_SCRIPT=/path/to/LongMemEval/src/evaluation/evaluate_qa.py
PRINT_SCRIPT=/path/to/LongMemEval/src/evaluation/print_qa_metrics.py
